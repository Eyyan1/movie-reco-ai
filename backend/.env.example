APP_NAME=Movie Reco AI API
APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/movie_reco_ai
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000
FRONTEND_ORIGIN_REGEX=
